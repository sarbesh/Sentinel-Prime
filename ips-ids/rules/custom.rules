# Sentinel Prime - Basic IDS Rules
# Custom rules for home network security monitoring

# Port Scans
alert tcp any any -> $HOME_NET any (msg:"SYN Port Scan"; flags:S; flow:to_server; detection_filter:track by_src,count 30,seconds 10; classtype:network-scan; sid:1000001; rev:1;)
alert tcp any any -> $HOME_NET any (msg:"Xmas Port Scan"; flags:FPU; classtype:network-scan; sid:1000002; rev:1;)
alert tcp any any -> $HOME_NET any (msg:"Null Port Scan"; flags:0; classtype:network-scan; sid:1000003; rev:1;)

# Brute Force - SSH
alert tcp any any -> $HOME_NET 22 (msg:"SSH Brute Force Attempt"; flow:to_server; flags:S; detection_filter:track by_dst,count 5,seconds 30; classtype:attempt-user; sid:1000101; rev:1;)

# Brute Force - FTP
alert tcp any any -> $HOME_NET 21 (msg:"FTP Brute Force Attempt"; flow:to_server; flags:S; detection_filter:track by_dst,count 5,seconds 60; classtype:attempt-user; sid:1000102; rev:1;)

# Brute Force - HTTP/HTTPS
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"HTTP Login Brute Force"; flow:to_server; content:"POST"; http_method; detection_filter:track by_dst,count 10,seconds 60; classtype:attempt-user; sid:1000103; rev:1;)

# SQL Injection Attempts
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"SQL Injection Attempt - SELECT"; flow:to_server; content:"SELECT"; http_uri; nocase; classtype:protocol-attack; sid:1000201; rev:1;)
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"SQL Injection Attempt - UNION"; flow:to_server; content:"UNION"; http_uri; nocase; classtype:protocol-attack; sid:1000202; rev:1;)
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"SQL Injection Attempt - OR 1=1"; flow:to_server; content:"OR 1=1"; http_uri; nocase; classtype:protocol-attack; sid:1000203; rev:1;)

# XSS Attempts
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"XSS Attempt - Script Tag"; flow:to_server; content:"<script"; http_uri; nocase; classtype:protocol-attack; sid:1000301; rev:1;)
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"XSS Attempt - Javascript"; flow:to_server; content:"javascript:"; http_uri; nocase; classtype:protocol-attack; sid:1000302; rev:1;)

# Command Injection
# Remove problematic content rules; Suricata expects hex for content:"|"
# alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"Command Injection Attempt - Pipe"; flow:to_server; content:"|"; http_uri; classtype:protocol-attack; sid:1000401; rev:1;)
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"Command Injection Attempt - Semicolon"; flow:to_server; content:"|3B|"; http_uri; classtype:protocol-attack; sid:1000402; rev:1;)
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"Command Injection Attempt - /etc/passwd"; flow:to_server; content:"/etc/passwd"; http_uri; classtype:protocol-attack; sid:1000403; rev:1;)

# Directory Traversal
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"Directory Traversal Attempt"; flow:to_server; content:"../"; http_uri; classtype:protocol-attack; sid:1000501; rev:1;)
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"Windows Directory Traversal"; flow:to_server; content:"..\\"; http_uri; classtype:protocol-attack; sid:1000502; rev:1;)

# Known Malware/Exploit Signatures
alert tcp any any -> $HOME_NET any (msg:"Suspicious User-Agent - curl"; flow:to_server; content:"curl"; http_user_agent; classtype:network-scan; sid:1000601; rev:1;)
alert tcp any any -> $HOME_NET any (msg:"Suspicious User-Agent - wget"; flow:to_server; content:"wget"; http_user_agent; classtype:network-scan; sid:1000602; rev:1;)
alert tcp any any -> $HOME_NET any (msg:"Suspicious User-Agent - python-requests"; flow:to_server; content:"python-requests"; http_user_agent; classtype:network-scan; sid:1000603; rev:1;)

# DNS Tunneling Detection
alert udp any any -> $HOME_NET 53 (msg:"Suspicious DNS Query Length"; flow:to_server; dsize:>100; classtype:protocol-attack; sid:1000701; rev:1;)

# CVE Specific Rules
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"Log4j RCE Attempt"; flow:to_server; content:"${jndi:"; http_uri; classtype:protocol-attack; sid:1000801; rev:1;)

# IoT Device Specific
alert tcp any any -> $HOME_NET 554 (msg:"RTSP Connection Attempt"; flow:to_server; classtype:attempt-user; sid:1000901; rev:1;)
alert tcp any any -> $HOME_NET 8080 (msg:"HTTP Proxy Connection"; flow:to_server; classtype:network-scan; sid:1000902; rev:1;)

# Denial of Service
alert icmp any any -> $HOME_NET any (msg:"ICMP Ping of Death"; flow:to_server; icode:0; itype:8; dsize:>64; classtype:denial-of-service; sid:1001001; rev:1;)
alert tcp any any -> $HOME_NET any (msg:"TCP SYN Flood"; flow:to_server; flags:S; detection_filter:track by_dst,count 100,seconds 10; classtype:denial-of-service; sid:1001002; rev:1;)

# Policy Violations
alert tcp any any -> $HOME_NET 445 (msg:"Non-Standard Port - SMB"; flow:to_server; classtype:policy-violation; sid:1001101; rev:1;)
alert tcp any any -> $HOME_NET 23 (msg:"Non-Standard Port - Telnet"; flow:to_server; classtype:policy-violation; sid:1001102; rev:1;)

# Local Network Specific
alert tcp $HOME_NET any -> any 4444 (msg:"Metasploit Default Callback"; classtype:protocol-attack; sid:1001201; rev:1;)
alert tcp $HOME_NET any -> any 5555 (msg:"Android ADB Default Port"; classtype:policy-violation; sid:1001202; rev:1;)
